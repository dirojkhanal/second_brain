{
  "info": {
    "name": "Second Brain API - Notes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete notes API endpoints with authentication"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "noteId",
      "value": "",
      "description": "Store a note ID for testing"
    }
  ],
  "item": [
    {
      "name": "Notes",
      "item": [
        {
          "name": "1. Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('noteId', response.data.note.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Note\",\n  \"content\": \"This is the content of my first note. It can be quite long and contain multiple paragraphs.\\n\\nHere's a second paragraph with some important information.\"\n}"
            }
          }
        },
        {
          "name": "2. Get All Notes (Default)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            },
            "description": "Gets first 20 notes, excluding archived"
          }
        },
        {
          "name": "3. Get All Notes (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["notes"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Gets 10 notes per page"
          }
        },
        {
          "name": "4. Get All Notes (Include Archived)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes?includeArchived=true",
              "host": ["{{baseUrl}}"],
              "path": ["notes"],
              "query": [
                { "key": "includeArchived", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "5. Get Single Note",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "description": "Uses noteId from Create Note response"
          }
        },
        {
          "name": "6. Update Note (Title Only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Note Title\"\n}"
            }
          }
        },
        {
          "name": "7. Update Note (Content Only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"This is updated content with new information.\"\n}"
            }
          }
        },
        {
          "name": "8. Update Note (Both)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fully Updated Note\",\n  \"content\": \"Both title and content have been updated.\"\n}"
            }
          }
        },
        {
          "name": "9. Search Notes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/search?query=note&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "search"],
              "query": [
                { "key": "query", "value": "note" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Full-text search with ranking"
          }
        },
        {
          "name": "10. Get Recent Notes (7 days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/recent",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "recent"]
            },
            "description": "Gets notes from last 7 days (default)"
          }
        },
        {
          "name": "11. Get Recent Notes (Custom Days)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/recent?days=14",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "recent"],
              "query": [
                { "key": "days", "value": "14" }
              ]
            },
            "description": "Gets notes from last 14 days"
          }
        },
        {
          "name": "12. Archive Note",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}", "archive"]
            },
            "description": "Toggles archive status"
          }
        },
        {
          "name": "13. Unarchive Note",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}/archive",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}", "archive"]
            },
            "description": "Toggle again to unarchive"
          }
        },
        {
          "name": "14. Batch Delete Notes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/batch/delete",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "batch", "delete"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noteIds\": [\n    \"replace-with-actual-uuid-1\",\n    \"replace-with-actual-uuid-2\"\n  ]\n}"
            },
            "description": "Delete multiple notes at once (max 100)"
          }
        },
        {
          "name": "15. Batch Archive Notes",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/batch/archive",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "batch", "archive"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"noteIds\": [\n    \"replace-with-actual-uuid-1\",\n    \"replace-with-actual-uuid-2\"\n  ],\n  \"archive\": true\n}"
            },
            "description": "Archive multiple notes (set archive: false to unarchive)"
          }
        },
        {
          "name": "16. Delete Note",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "description": "Permanently delete a note"
          }
        }
      ]
    },
    {
      "name": "Validation Tests",
      "item": [
        {
          "name": "Empty Title (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"content\": \"Content here\"\n}"
            }
          }
        },
        {
          "name": "Title Too Long (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"This is a very long title that exceeds the maximum allowed length of 255 characters. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.\",\n  \"content\": \"Content\"\n}"
            }
          }
        },
        {
          "name": "Missing Content (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": ["{{baseUrl}}"],
              "path": ["notes"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Valid Title\"\n}"
            }
          }
        },
        {
          "name": "Invalid Note ID (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/not-a-valid-uuid",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "not-a-valid-uuid"]
            }
          }
        },
        {
          "name": "Update Nothing (400)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "{{noteId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "Search Query Too Short (400)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/search?query=a",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "search"],
              "query": [
                { "key": "query", "value": "a" }
              ]
            }
          }
        },
        {
          "name": "Non-existent Note (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["notes", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    }
  ]
}